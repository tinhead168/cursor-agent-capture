{
  "manifest_version": 3,
  "name": "Cursor Agent Capture",
  "version": "2.0.0",
  "description": "Click icon on any cursor.com/agents page. JSON downloads instantly.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
